# ============================================================
# Apex Academy GCSE — frontend environment variables
# Copy this file to ".env" (or ".env.local") and fill in real values.
# Vite only exposes variables prefixed with VITE_ to the browser.
# ============================================================

# Base URL of the existing Apex Academy Render backend (Express + Postgres + JWT).
# The GCSE frontend reads this at build time.
#
#   • SET it (e.g. https://apex-backend.onrender.com) for production: real
#     accounts, real progress, and real Safaricom Daraja M-Pesa payments.
#
#   • LEAVE it unset to run in offline demo mode, where auth, progress and the
#     "M-Pesa" upgrade are simulated in the browser's localStorage. In demo
#     mode the app also seeds the trial logins listed in the README so every
#     area is reachable without a backend.
VITE_API_URL=https://your-apex-backend.onrender.com
